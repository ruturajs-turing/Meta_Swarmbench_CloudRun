{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AegisRun Foundry normalized task spec",
  "type": "object",
  "required": ["version", "run", "resources", "image", "inputs", "outputs", "network", "limits"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "run": {
      "type": "object",
      "required": ["name", "command", "working_dir", "timeout_seconds", "result_file"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "working_dir": { "type": "string", "pattern": "^/run/task" },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "result_file": { "type": "string", "minLength": 1 }
      }
    },
    "resources": {
      "type": "object",
      "required": ["profile", "cpu", "memory_gb", "disk_gb", "gpu"],
      "additionalProperties": false,
      "properties": {
        "profile": { "enum": ["small", "medium", "large", "xlarge", "gpu-a10"] },
        "cpu": { "type": "integer", "minimum": 1, "maximum": 64 },
        "memory_gb": { "type": "integer", "minimum": 1, "maximum": 512 },
        "disk_gb": { "type": "integer", "minimum": 1, "maximum": 2048 },
        "gpu": { "type": "string" }
      }
    },
    "image": {
      "type": "object",
      "required": ["registry", "repository", "tag", "digest"],
      "additionalProperties": false,
      "properties": {
        "registry": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^sha256:.+" }
      }
    },
    "inputs": {
      "type": "object",
      "required": ["include", "exclude", "max_upload_mb"],
      "additionalProperties": false,
      "properties": {
        "include": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "exclude": { "type": "array", "items": { "type": "string" } },
        "max_upload_mb": { "type": "integer", "minimum": 1 }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["include", "max_output_mb"],
      "additionalProperties": false,
      "properties": {
        "include": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "max_output_mb": { "type": "integer", "minimum": 1 }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^vault://.+" }
    },
    "network": {
      "type": "object",
      "required": ["egress", "allow"],
      "additionalProperties": false,
      "properties": {
        "egress": { "enum": ["deny", "allowlist"] },
        "allow": { "type": "array", "items": { "type": "string" } }
      }
    },
    "limits": {
      "type": "object",
      "required": ["max_cost_usd", "max_retries"],
      "additionalProperties": false,
      "properties": {
        "max_cost_usd": { "type": "number", "minimum": 0 },
        "max_retries": { "type": "integer", "minimum": 0, "maximum": 5 }
      }
    }
  }
}
